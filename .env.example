# API Keys
NEWS_API_KEY=your_newsapi_key_here
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
CRYPTO_COMPARE_API_KEY=your_crypto_compare_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# API Endpoints (optional - defaults provided)
# FINNHUB_BASE_URL=https://finnhub.io/api/v1
# ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
# CRYPTO_COMPARE_BASE_URL=https://min-api.cryptocompare.com/data
# NEWSAPI_BASE_URL=https://newsapi.org/v2

# Cache Configuration (optional - defaults provided)
# MARKET_CACHE_TTL=30
# SENTIMENT_CACHE_TTL=300

# Request Configuration (optional - defaults provided)
# REQUEST_TIMEOUT=10
# MAX_RETRIES=2

# Database (MySQL / AWS RDS)
# Prefer DATABASE_URL. If omitted, DB_* values are used.
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname
# DB_HOST=your-rds-endpoint.amazonaws.com
# DB_PORT=3306
# DB_NAME=sentimarket
# DB_USER=your_user
# DB_PASSWORD=your_password
